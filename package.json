{
  "name": "context-pilot",
  "displayName": "Context Pilot",
  "description": "Save, restore, and switch your full editor context — open files, cursor positions, layout, and more.",
  "version": "0.1.0",
  "publisher": "anxin233",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anxin233/context-pilot.git"
  },
  "homepage": "https://github.com/anxin233/context-pilot#readme",
  "bugs": {
    "url": "https://github.com/anxin233/context-pilot/issues"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Productivity",
    "Other"
  ],
  "keywords": [
    "context",
    "snapshot",
    "workspace",
    "switch",
    "bookmark",
    "session",
    "restore"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "files": [
    "out/**",
    "images/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "contributes": {
    "commands": [
      {
        "command": "contextPilot.save",
        "title": "Context Pilot: Save Snapshot",
        "icon": "$(add)"
      },
      {
        "command": "contextPilot.restore",
        "title": "Context Pilot: Restore Snapshot",
        "icon": "$(history)"
      },
      {
        "command": "contextPilot.delete",
        "title": "Context Pilot: Delete Snapshot",
        "icon": "$(trash)"
      },
      {
        "command": "contextPilot.rename",
        "title": "Context Pilot: Rename Snapshot",
        "icon": "$(edit)"
      },
      {
        "command": "contextPilot.toggleAutoSwitch",
        "title": "Context Pilot: Toggle Auto Branch Switch"
      },
      {
        "command": "contextPilot.treeRestore",
        "title": "Restore",
        "icon": "$(history)"
      },
      {
        "command": "contextPilot.treeDelete",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "contextPilot.treeRename",
        "title": "Rename",
        "icon": "$(edit)"
      },
      {
        "command": "contextPilot.treeUpdate",
        "title": "Update Snapshot",
        "icon": "$(refresh)"
      },
      {
        "command": "contextPilot.refreshTree",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "contextPilot.exportSnapshot",
        "title": "Context Pilot: Export Snapshot"
      },
      {
        "command": "contextPilot.importSnapshot",
        "title": "Context Pilot: Import Snapshot"
      },
      {
        "command": "contextPilot.compareSnapshots",
        "title": "Context Pilot: Compare Snapshots"
      },
      {
        "command": "contextPilot.quickSwitch1",
        "title": "Context Pilot: Quick Switch Slot 1"
      },
      {
        "command": "contextPilot.quickSwitch2",
        "title": "Context Pilot: Quick Switch Slot 2"
      },
      {
        "command": "contextPilot.quickSwitch3",
        "title": "Context Pilot: Quick Switch Slot 3"
      },
      {
        "command": "contextPilot.quickSwitch4",
        "title": "Context Pilot: Quick Switch Slot 4"
      },
      {
        "command": "contextPilot.quickSwitch5",
        "title": "Context Pilot: Quick Switch Slot 5"
      },
      {
        "command": "contextPilot.quickSwitch6",
        "title": "Context Pilot: Quick Switch Slot 6"
      },
      {
        "command": "contextPilot.quickSwitch7",
        "title": "Context Pilot: Quick Switch Slot 7"
      },
      {
        "command": "contextPilot.quickSwitch8",
        "title": "Context Pilot: Quick Switch Slot 8"
      },
      {
        "command": "contextPilot.quickSwitch9",
        "title": "Context Pilot: Quick Switch Slot 9"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "contextPilot",
          "title": "Context Pilot",
          "icon": "$(bookmark)"
        }
      ]
    },
    "views": {
      "contextPilot": [
        {
          "id": "contextPilotExplorer",
          "name": "Snapshots",
          "icon": "$(bookmark)",
          "contextualTitle": "Context Pilot"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "contextPilot.save",
          "when": "view == contextPilotExplorer",
          "group": "navigation"
        },
        {
          "command": "contextPilot.refreshTree",
          "when": "view == contextPilotExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "contextPilot.treeRestore",
          "when": "view == contextPilotExplorer && viewItem == snapshot",
          "group": "inline@1"
        },
        {
          "command": "contextPilot.treeUpdate",
          "when": "view == contextPilotExplorer && viewItem == snapshot",
          "group": "inline@2"
        },
        {
          "command": "contextPilot.treeRestore",
          "when": "view == contextPilotExplorer && viewItem == snapshot",
          "group": "1_actions@1"
        },
        {
          "command": "contextPilot.treeUpdate",
          "when": "view == contextPilotExplorer && viewItem == snapshot",
          "group": "1_actions@2"
        },
        {
          "command": "contextPilot.treeRename",
          "when": "view == contextPilotExplorer && viewItem == snapshot",
          "group": "2_edit@1"
        },
        {
          "command": "contextPilot.treeDelete",
          "when": "view == contextPilotExplorer && viewItem == snapshot",
          "group": "2_edit@2"
        }
      ],
      "commandPalette": [
        {
          "command": "contextPilot.treeRestore",
          "when": "false"
        },
        {
          "command": "contextPilot.treeDelete",
          "when": "false"
        },
        {
          "command": "contextPilot.treeRename",
          "when": "false"
        },
        {
          "command": "contextPilot.treeUpdate",
          "when": "false"
        },
        {
          "command": "contextPilot.refreshTree",
          "when": "false"
        },
        {
          "command": "contextPilot.quickSwitch1",
          "when": "false"
        },
        {
          "command": "contextPilot.quickSwitch2",
          "when": "false"
        },
        {
          "command": "contextPilot.quickSwitch3",
          "when": "false"
        },
        {
          "command": "contextPilot.quickSwitch4",
          "when": "false"
        },
        {
          "command": "contextPilot.quickSwitch5",
          "when": "false"
        },
        {
          "command": "contextPilot.quickSwitch6",
          "when": "false"
        },
        {
          "command": "contextPilot.quickSwitch7",
          "when": "false"
        },
        {
          "command": "contextPilot.quickSwitch8",
          "when": "false"
        },
        {
          "command": "contextPilot.quickSwitch9",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Context Pilot",
      "properties": {
        "contextPilot.confirmBeforeRestore": {
          "type": "boolean",
          "default": true,
          "description": "Show a confirmation dialog before restoring a snapshot (closes all current editors)."
        },
        "contextPilot.maxSnapshots": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "maximum": 200,
          "description": "Maximum number of snapshots to keep. Oldest snapshots are removed when exceeded."
        },
        "contextPilot.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show the Context Pilot status bar item."
        },
        "contextPilot.autoSwitchOnBranch": {
          "type": "boolean",
          "default": false,
          "description": "Automatically save/restore snapshots when switching Git branches."
        },
        "contextPilot.quickSwitchSlots": {
          "type": "number",
          "default": 9,
          "minimum": 1,
          "maximum": 9,
          "description": "Number of quick-switch slots (1-9) accessible via Ctrl+Alt+[N]."
        }
      }
    },
    "keybindings": [
      {
        "command": "contextPilot.save",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s"
      },
      {
        "command": "contextPilot.restore",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l"
      },
      {
        "command": "contextPilot.quickSwitch1",
        "key": "ctrl+alt+1",
        "mac": "cmd+alt+1"
      },
      {
        "command": "contextPilot.quickSwitch2",
        "key": "ctrl+alt+2",
        "mac": "cmd+alt+2"
      },
      {
        "command": "contextPilot.quickSwitch3",
        "key": "ctrl+alt+3",
        "mac": "cmd+alt+3"
      },
      {
        "command": "contextPilot.quickSwitch4",
        "key": "ctrl+alt+4",
        "mac": "cmd+alt+4"
      },
      {
        "command": "contextPilot.quickSwitch5",
        "key": "ctrl+alt+5",
        "mac": "cmd+alt+5"
      },
      {
        "command": "contextPilot.quickSwitch6",
        "key": "ctrl+alt+6",
        "mac": "cmd+alt+6"
      },
      {
        "command": "contextPilot.quickSwitch7",
        "key": "ctrl+alt+7",
        "mac": "cmd+alt+7"
      },
      {
        "command": "contextPilot.quickSwitch8",
        "key": "ctrl+alt+8",
        "mac": "cmd+alt+8"
      },
      {
        "command": "contextPilot.quickSwitch9",
        "key": "ctrl+alt+9",
        "mac": "cmd+alt+9"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  }
}
